{
	"name": "kv1-vscode",
	"displayName": "Valve KeyValues1",
	"description": "Syntax highlighting and diagnostics for Valve KeyValues1 files in DOTA2",
	"version": "0.0.3",
	"publisher": "SanctusAnimus",
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [
		"onLanguage:kv1",
		"onCommand:kv1.configureDotaFileAssociations",
		"onCommand:kv1.removeDotaFileAssociations"
	],
	"main": "./out/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "kv1",
				"aliases": [
					"Valve KeyValues1",
					"KV1",
					"KeyValues"
				],
				"extensions": [
					".kv"
				],
				"filenamePatterns": [
					"npc_heroes_custom.txt",
					"npc_units_custom.txt",
					"npc_abilities_custom.txt",
					"npc_abilities_override.txt",
					"npc_items_custom.txt",
					"neutral_items.txt",
					"herolist.txt",
					"shops.txt",
					"custom.gameevents",
					"npc_items_override.txt"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "kv1",
				"scopeName": "source.kv1",
				"path": "./syntaxes/kv1.tmLanguage.json"
			}
		],
		"commands": [
			{
				"command": "kv1.configureDotaFileAssociations",
				"title": "KV1: Configure Dota File Associations"
			},
			{
				"command": "kv1.removeDotaFileAssociations",
				"title": "KV1: Remove Dota File Associations"
			}
		],
		"snippets": [
			{
				"language": "kv1",
				"path": "./snippets/kv1.json"
			}
		]
	},
	"scripts": {
		"generate-snippets": "node scripts/generate-snippets.mjs",
		"compile": "npm run generate-snippets && tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.100.0",
		"@vscode/vsce": "^3.9.2",
		"typescript": "^5.0.0"
	}
}

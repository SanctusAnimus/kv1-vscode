{
  "Dota Ability Lua": {
    "prefix": "kvability",
    "body": [
      "\"${1:ability_name}\"",
      "{",
      "\t\"BaseClass\"\t\t\t\t\"ability_lua\"",
      "\t\"ScriptFile\"\t\t\t\"abilities/${1:ability_name}\"",
      "\t\"AbilityTextureName\"\t\"${1:ability_name}\"",
      "",
      "\t\"AbilityBehavior\"\t\t\t\"DOTA_ABILITY_BEHAVIOR_NO_TARGET\"",
      "\t\"AbilityUnitTargetTeam\"\t\t\"DOTA_UNIT_TARGET_TEAM_ENEMY\"",
      "\t\"AbilityUnitTargetType\"\t\t\"DOTA_UNIT_TARGET_HERO | DOTA_UNIT_TARGET_BASIC\"",
      "\t\"AbilityUnitDamageType\"\t\t\"DAMAGE_TYPE_PHYSICAL\"",
      "",
      "\t\"AbilityCooldown\"\t\t\"10\"",
      "\t\"AbilityManaCost\"\t\t\"400\"",
      "",
      "\t\"AbilityCastAnimation\"\t\t\t\"ACT_DOTA_CAST_ABILITY_1\"",
      "\t\"AbilityCastPoint\"\t\t\t\t\"0.2\"",
      "\t\"AbilityCastRange\"\t\t\t\t\"1000\"",
      "",
      "\t\"AbilityValues\"",
      "\t{",
      "\t\t\"damage\"\t\t\t\"100\"",
      "\t}",
      "}",
      ""
    ],
    "description": "Insert a basic Dota Lua ability block"
  },
